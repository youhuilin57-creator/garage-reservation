generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────
// 店舗（マルチテナント）
// ─────────────────────────────────

model Shop {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  address           String?
  phone             String?
  email             String?
  openTime          String   @default("08:00")
  closeTime         String   @default("20:00")
  slotMin           Int      @default(30)
  taxRegistrationNo String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users                User[]
  customers            Customer[]
  vehicles             Vehicle[]
  reservations         Reservation[]
  mechanics            Mechanic[]
  services             Service[]
  invoices             Invoice[]
  closedDays           ShopClosedDay[]
  nextServiceReminders NextServiceReminder[]
  reservationTokens    ReservationToken[]
}

// ─────────────────────────────────
// 認証・ユーザー
// ─────────────────────────────────

enum UserRole {
  ADMIN
  RECEPTIONIST
  MECHANIC
}

model User {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(RECEPTIONIST)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mechanic      Mechanic?
  refreshTokens RefreshToken[]

  @@index([shopId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─────────────────────────────────
// 顧客
// ─────────────────────────────────

model Customer {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id])
  name      String
  kana      String?
  phone     String?
  email     String?
  address   String?
  birthday  DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicles     Vehicle[]
  reservations Reservation[]

  @@index([shopId])
  @@index([phone])
  @@index([name])
}

// ─────────────────────────────────
// 車両
// ─────────────────────────────────

model Vehicle {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id])
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  plateNumber    String
  make           String
  model          String
  modelCode      String?
  year           Int?
  vin            String?
  color          String?
  inspectionDate DateTime?
  lastMileage    Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  reservations         Reservation[]
  nextServiceReminders NextServiceReminder[]

  @@index([shopId])
  @@index([customerId])
  @@index([plateNumber])
  @@index([inspectionDate])
}

// ─────────────────────────────────
// 整備メニュー
// ─────────────────────────────────

model Service {
  id               String   @id @default(cuid())
  shopId           String
  shop             Shop     @relation(fields: [shopId], references: [id])
  name             String
  description      String?
  durationMin      Int
  basePrice        Decimal? @db.Decimal(10, 2)
  requiresApproval Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reservationServices ReservationService[]
  mechanicServices    MechanicService[]

  @@index([shopId])
}

// ─────────────────────────────────
// 予約
// ─────────────────────────────────

enum ReservationStatus {
  PENDING
  RESERVED
  CHECKED_IN
  IN_PROGRESS
  WAITING_FOR_PARTS
  COMPLETED
  DELIVERED
  CANCELLED
}

model Reservation {
  id               String            @id @default(cuid())
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id])
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id])
  vehicleId        String
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id])
  mechanicId       String?
  mechanic         Mechanic?         @relation(fields: [mechanicId], references: [id])
  startAt          DateTime
  endAt            DateTime
  status           ReservationStatus @default(RESERVED)
  isWalkIn         Boolean           @default(false)
  notes            String?
  internalNotes    String?
  freeWorkNote     String?
  mileageAtService Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  services      ReservationService[]
  statusLogs    ReservationStatusLog[]
  parts         ReservationPart[]
  reminders     Reminder[]
  serviceRecord ServiceRecord?
  invoice       Invoice?

  @@index([shopId])
  @@index([customerId])
  @@index([vehicleId])
  @@index([mechanicId])
  @@index([startAt, endAt])
  @@index([status])
}

model ReservationService {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  price         Decimal?    @db.Decimal(10, 2)
  notes         String?

  @@index([reservationId])
}

model ReservationStatusLog {
  id              String             @id @default(cuid())
  reservationId   String
  reservation     Reservation        @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  fromStatus      ReservationStatus?
  toStatus        ReservationStatus
  changedByUserId String?
  notes           String?
  createdAt       DateTime           @default(now())

  @@index([reservationId])
}

// ─────────────────────────────────
// 部品使用記録
// ─────────────────────────────────

model ReservationPart {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  partNumber    String?
  name          String
  unitPrice     Decimal     @db.Decimal(10, 2)
  quantity      Int         @default(1)
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([reservationId])
}

// ─────────────────────────────────
// 整備記録書
// ─────────────────────────────────

model ServiceRecord {
  id                String      @id @default(cuid())
  reservationId     String      @unique
  reservation       Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  mileageAtDelivery Int?
  workSummary       String?
  nextRecommend     String?
  createdByUserId   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// ─────────────────────────────────
// 次回点検・定期リマインド
// ─────────────────────────────────

enum NextServiceType {
  SHAKEN
  PERIODIC
  OIL_CHANGE
  TIRE_ROTATION
  OTHER
}

model NextServiceReminder {
  id          String          @id @default(cuid())
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id])
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id])
  type        NextServiceType
  title       String
  dueDate     DateTime
  reminderAt  DateTime[]
  isSent      Boolean         @default(false)
  isCompleted Boolean         @default(false)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([shopId])
  @@index([vehicleId])
  @@index([dueDate])
}

// ─────────────────────────────────
// 整備士
// ─────────────────────────────────

model Mechanic {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  color     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations     Reservation[]
  mechanicServices MechanicService[]
  workHours        MechanicWorkHour[]
  schedules        MechanicSchedule[]

  @@index([shopId])
}

model MechanicService {
  mechanicId String
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([mechanicId, serviceId])
}

// 整備士の通常勤務時間（曜日別 0=日〜6=土）
model MechanicWorkHour {
  id         String   @id @default(cuid())
  mechanicId String
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  isWorkDay  Boolean  @default(true)
  startTime  String?
  endTime    String?

  @@unique([mechanicId, dayOfWeek])
  @@index([mechanicId])
}

// 整備士の臨時スケジュール（休暇・時短等）
model MechanicSchedule {
  id         String   @id @default(cuid())
  mechanicId String
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  isHoliday  Boolean  @default(false)
  startTime  String?
  endTime    String?
  notes      String?

  @@unique([mechanicId, date])
  @@index([mechanicId, date])
}

// ─────────────────────────────────
// 工場カレンダー（臨時休業・特別時間）
// ─────────────────────────────────

model ShopClosedDay {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  allDay    Boolean  @default(true)
  startTime String?
  endTime   String?
  reason    String?

  @@unique([shopId, date])
  @@index([shopId, date])
}

// ─────────────────────────────────
// 請求書
// ─────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

model Invoice {
  id            String         @id @default(cuid())
  shopId        String
  shop          Shop           @relation(fields: [shopId], references: [id])
  reservationId String         @unique
  reservation   Reservation    @relation(fields: [reservationId], references: [id])
  invoiceNumber String         @unique
  status        InvoiceStatus  @default(DRAFT)
  paymentMethod PaymentMethod?
  issueDate     DateTime       @default(now())
  dueDate       DateTime?
  subtotal      Decimal        @db.Decimal(10, 2)
  taxRate       Decimal        @db.Decimal(4, 2) @default(0.10)
  taxAmount     Decimal        @db.Decimal(10, 2)
  totalAmount   Decimal        @db.Decimal(10, 2)
  notes         String?
  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items InvoiceItem[]

  @@index([shopId])
  @@index([invoiceNumber])
  @@index([status])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  amount    Decimal @db.Decimal(10, 2)

  @@index([invoiceId])
}

// ─────────────────────────────────
// リマインド通知
// ─────────────────────────────────

enum ReminderType {
  BOOKING_CONFIRM
  REMINDER_DAY_BEFORE
  REMINDER_MORNING
  REMINDER_1H_BEFORE
  WORK_COMPLETED
  NEXT_SERVICE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model Reminder {
  id            String         @id @default(cuid())
  reservationId String
  reservation   Reservation    @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          ReminderType
  status        ReminderStatus @default(PENDING)
  scheduledAt   DateTime
  sentAt        DateTime?
  errorMessage  String?

  @@index([scheduledAt, status])
  @@index([reservationId])
}

// ─────────────────────────────────
// 顧客セルフ予約トークン
// ─────────────────────────────────

model ReservationToken {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id])
  token     String    @unique @default(cuid())
  label     String?
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([shopId])
  @@index([token])
}
