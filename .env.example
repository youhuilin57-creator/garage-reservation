# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/garage_reservation"

# ─── API ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# JWT (openssl rand -hex 64 で生成)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@your-domain.com

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Railway (本番) ──────────────────────────────────────
# DATABASE_URL は Railway が自動設定
# RAILWAY_STATIC_URL=https://api.your-app.up.railway.app

# ─── インボイス ──────────────────────────────────────────
INVOICE_TAX_RATE=0.10
INVOICE_REGISTRANT_NUMBER=T0000000000000  # インボイス登録番号
